# ══════════════════════════════════════════════════════════════════
# Human Communication Agent — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ══════════════════════════════════════════════════════════════════

# ── Google Gemini ─────────────────────────────────────────────────
GOOGLE_API_KEY=your-google-gemini-api-key-here
LLM_MODEL=gemini-2.5-pro

# ── LangSmith tracing (optional but recommended) ─────────────────
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=your-langsmith-api-key-here
LANGSMITH_PROJECT=hca-digital-twin

# ── Pinecone vector store ─────────────────────────────────────────
PINECONE_API_KEY=your-pinecone-api-key-here
PINECONE_INDEX=hca-twin-memory
# PINECONE_ENVIRONMENT=us-east-1-aws  # only needed for older SDK

# ── Weaviate vector store ─────────────────────────────────────────
WEAVIATE_URL=https://your-cluster.weaviate.network
WEAVIATE_API_KEY=your-weaviate-api-key-here

# ── Redis cache ───────────────────────────────────────────────────
# Leave empty to use in-memory fallback (dev mode)
REDIS_URL=redis://localhost:6379/0

# ── PostgreSQL (production memory + user DB) ─────────────────────
# Leave empty to use in-memory fallbacks (dev mode)
POSTGRES_URI=postgresql://user:password@localhost:5432/hca_db

# ── JWT Auth ──────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string-in-production

# ── Flask ─────────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_PORT=5002
