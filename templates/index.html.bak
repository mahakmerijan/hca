<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>🧠 AI Behaviour Counsellor</title>
<!-- html2pdf.js for PDF export -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#0b0d13;--card:#13161f;--card2:#1a1e2b;--border:#252a3a;
  --accent:#7c6af6;--accent2:#a599ff;--accentGlow:rgba(124,106,246,.18);
  --green:#2dd4a8;--greenBg:rgba(45,212,168,.10);--greenBorder:rgba(45,212,168,.28);
  --yellow:#f5c542;--yellowBg:rgba(245,197,66,.10);--yellowBorder:rgba(245,197,66,.28);
  --red:#f87171;--redBg:rgba(248,113,113,.10);--redBorder:rgba(248,113,113,.25);
  --orange:#fb923c;--orangeBg:rgba(251,146,60,.10);--orangeBorder:rgba(251,146,60,.25);
  --text:#d1d5e0;--muted:#7a809a;--white:#f0f2f8;
  --radius:16px;--shadow:0 4px 24px rgba(0,0,0,.4);
  --font:'Inter',system-ui,-apple-system,sans-serif;
}
html{font-size:15px;scroll-behavior:smooth}
body{font-family:var(--font);background:var(--bg);color:var(--text);min-height:100vh;display:flex;flex-direction:column;align-items:center}
.hidden{display:none!important}
.fade-in{animation:fadeIn .55s ease forwards;opacity:0}
@keyframes fadeIn{to{opacity:1}}
@keyframes spin{to{transform:rotate(360deg)}}
@keyframes slideUp{from{opacity:0;transform:translateY(18px)}to{opacity:1;transform:translateY(0)}}
.slide-up{animation:slideUp .5s ease forwards;opacity:0}

/* ─── Header ─── */
header{width:100%;max-width:960px;text-align:center;padding:52px 24px 8px}
header h1{font-size:1.9rem;font-weight:800;color:var(--white);letter-spacing:-.3px}
header h1 .ai{background:linear-gradient(135deg,var(--accent),#b396ff);-webkit-background-clip:text;-webkit-text-fill-color:transparent}
header p{color:var(--muted);margin-top:8px;font-size:.92rem;line-height:1.6;max-width:540px;margin-inline:auto}

/* ─── Upload ─── */
#upload-section{width:100%;max-width:600px;margin:36px auto 0;background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:42px 36px;box-shadow:var(--shadow);text-align:center}
.drop-zone{border:2px dashed var(--border);border-radius:14px;padding:52px 24px;cursor:pointer;transition:.25s}
.drop-zone:hover,.drop-zone.drag-over{border-color:var(--accent);background:var(--accentGlow)}
.drop-zone .icon{font-size:3.2rem;margin-bottom:10px}
.drop-zone p{color:var(--muted);font-size:.9rem;line-height:1.6}
.drop-zone p strong{color:var(--accent2)}
#file-input{display:none}
#file-name{margin-top:14px;font-size:.86rem;color:var(--green);min-height:22px}
#analyze-btn{margin-top:24px;padding:14px 52px;font-size:1rem;font-weight:700;background:linear-gradient(135deg,var(--accent),#9585ff);color:#fff;border:none;border-radius:12px;cursor:pointer;transition:.25s;letter-spacing:.2px}
#analyze-btn:hover{transform:translateY(-2px);box-shadow:0 8px 28px rgba(124,106,246,.35)}
#analyze-btn:disabled{opacity:.4;cursor:not-allowed;transform:none;box-shadow:none}

/* ─── Progress ─── */
#progress-section{width:100%;max-width:600px;margin:36px auto 0;background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:40px;box-shadow:var(--shadow);text-align:center}
.spinner{width:52px;height:52px;border:4px solid var(--border);border-top-color:var(--accent);border-radius:50%;animation:spin .75s linear infinite;margin:0 auto 20px}
#progress-text{color:var(--accent2);font-size:1.05rem;font-weight:600}
#progress-sub{color:var(--muted);font-size:.83rem;margin-top:8px}

/* ─── Results ─── */
#results-section{width:100%;max-width:960px;margin:40px auto 64px;display:flex;flex-direction:column;gap:24px;padding:0 12px}

/* ─── Counsellor Header ─── */
.counsellor-banner{background:linear-gradient(135deg,rgba(124,106,246,.12),rgba(45,212,168,.06));border:1px solid rgba(124,106,246,.22);border-radius:var(--radius);padding:28px 32px;text-align:center}
.counsellor-banner h2{font-size:1.3rem;font-weight:800;color:var(--white);margin-bottom:8px}
.counsellor-banner .subtitle{color:var(--accent2);font-size:.88rem;font-weight:500;margin-bottom:16px}
.counsellor-banner .summary{color:var(--text);font-size:.96rem;line-height:1.75;max-width:700px;margin:0 auto}
.counsellor-banner .personality{color:#b0b5cc;font-size:.9rem;line-height:1.6;margin-top:12px;font-style:italic}

/* ─── Card ─── */
.card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:28px 30px;box-shadow:var(--shadow)}
.card h2{font-size:1.1rem;font-weight:700;color:var(--white);margin-bottom:18px;display:flex;align-items:center;gap:10px}
.card h3{font-size:.95rem;font-weight:600;color:var(--accent2);margin:20px 0 10px}

/* ─── Strengths / Weaknesses ─── */
.sw-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px}
@media(max-width:680px){.sw-grid{grid-template-columns:1fr}}
.sw-item{padding:18px 20px;border-radius:12px;line-height:1.6}
.sw-item .sw-title{font-weight:700;font-size:.9rem;margin-bottom:6px;display:flex;align-items:center;gap:8px}
.sw-item .sw-detail{font-size:.85rem;color:#c8cce0;line-height:1.7}
.sw-strength{background:var(--greenBg);border:1px solid var(--greenBorder)}
.sw-strength .sw-title{color:var(--green)}
.sw-weakness{background:var(--redBg);border:1px solid var(--redBorder)}
.sw-weakness .sw-title{color:var(--red)}

/* ─── Scenario Cards ─── */
.scenario-cards{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}
@media(max-width:720px){.scenario-cards{grid-template-columns:1fr}}
.scenario-card{background:var(--card2);border:1px solid var(--border);border-radius:14px;padding:26px 22px;text-align:center;transition:.25s}
.scenario-card:hover{border-color:var(--accent);transform:translateY(-2px)}
.scenario-card .sc-emoji{font-size:2.2rem;margin-bottom:6px}
.scenario-card .sc-label{font-size:.8rem;text-transform:uppercase;letter-spacing:.5px;color:#b0b5cc;margin-bottom:14px;font-weight:600}
.ring-wrap{position:relative;width:110px;height:110px;margin:0 auto 12px}
.ring-wrap svg{transform:rotate(-90deg)}
.ring-bg{fill:none;stroke:var(--border);stroke-width:7}
.ring-fg{fill:none;stroke-width:7;stroke-linecap:round;transition:stroke-dashoffset 1.2s ease}
.ring-text{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-size:1.4rem;font-weight:800}
.scenario-card .sc-verdict{font-size:.84rem;font-weight:700;margin-bottom:10px;color:var(--white)}
.scenario-card .sc-advice{font-size:.84rem;color:#c8cce0;line-height:1.7;text-align:left;margin-top:12px;padding-top:12px;border-top:1px solid var(--border)}

/* ─── Improvement Plan ─── */
.plan-item{background:var(--card2);border:1px solid var(--border);border-radius:12px;padding:22px 24px;margin-bottom:14px}
.plan-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:10px}
.plan-area{font-weight:700;font-size:.95rem;color:var(--white)}
.plan-priority{font-size:.72rem;font-weight:700;padding:3px 12px;border-radius:20px;text-transform:uppercase;letter-spacing:.4px}
.priority-high{background:var(--redBg);color:var(--red);border:1px solid var(--redBorder)}
.priority-medium{background:var(--yellowBg);color:var(--yellow);border:1px solid var(--yellowBorder)}
.priority-low{background:var(--greenBg);color:var(--green);border:1px solid var(--greenBorder)}
.plan-states{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:12px}
.plan-state{font-size:.84rem;line-height:1.6;padding:10px 14px;border-radius:8px;color:#c8cce0}
.plan-state .ps-label{font-size:.7rem;text-transform:uppercase;letter-spacing:.4px;font-weight:600;margin-bottom:4px}
.state-now{background:var(--redBg);border:1px solid var(--redBorder)}
.state-now .ps-label{color:var(--red)}
.state-target{background:var(--greenBg);border:1px solid var(--greenBorder)}
.state-target .ps-label{color:var(--green)}
.plan-steps{list-style:none;padding:0}
.plan-steps li{font-size:.84rem;color:var(--text);padding:6px 0 6px 22px;position:relative;line-height:1.5}
.plan-steps li::before{content:'→';position:absolute;left:0;color:var(--accent2);font-weight:700}

/* ─── Closing ─── */
.closing-box{background:linear-gradient(135deg,var(--accentGlow),rgba(45,212,168,.06));border:1px solid rgba(124,106,246,.22);border-radius:14px;padding:24px 28px;text-align:center;font-size:.96rem;line-height:1.75;color:var(--white)}

/* ─── Score Bars ─── */
.bar-group{margin-bottom:14px}
.bar-label{display:flex;justify-content:space-between;font-size:.83rem;margin-bottom:5px}
.bar-label span:first-child{color:var(--text)}
.bar-label span:last-child{font-weight:700}
.bar-track{height:8px;background:var(--card2);border-radius:6px;overflow:hidden}
.bar-fill{height:100%;border-radius:6px;transition:width 1s ease}

/* ─── Footer ─── */
footer{padding:28px;text-align:center;color:var(--muted);font-size:.76rem}
</style>
</head>
<body>

<header>
  <h1>🧠 Your Personal <span class="ai">AI Behaviour Counsellor</span></h1>
  <p>Upload a video of yourself — our AI will analyse your facial expressions, body language &amp; speech, then give you personalised coaching to help you succeed.</p>
</header>

<!-- ═══ UPLOAD ═══ -->
<div id="upload-section">
  <div class="drop-zone" id="drop-zone">
    <div class="icon">🎬</div>
    <p>Drag &amp; drop your video here<br>or <strong>click to browse</strong></p>
    <p style="margin-top:10px;font-size:.76rem;color:var(--muted)">MP4 · AVI · MOV · MKV · WEBM — up to 500 MB</p>
    <input type="file" id="file-input" accept="video/*">
  </div>
  <div id="file-name"></div>
  <button id="analyze-btn" disabled>🔍 Start Counselling Session</button>
</div>

<!-- ═══ PROGRESS ═══ -->
<div id="progress-section" class="hidden">
  <div class="spinner"></div>
  <div id="progress-text">Starting analysis…</div>
  <div id="progress-sub">Our AI counsellor is studying your video — this takes 1–2 minutes</div>
</div>

<!-- ═══ RESULTS ═══ -->
<div id="results-section" class="hidden"></div>

<footer>AI Behaviour Counsellor — Powered by Gemini AI · DeepFace · MediaPipe · Librosa</footer>

<script>
const dropZone=document.getElementById('drop-zone'),fileInput=document.getElementById('file-input'),
      fileNameEl=document.getElementById('file-name'),analyzeBtn=document.getElementById('analyze-btn'),
      uploadSec=document.getElementById('upload-section'),progressSec=document.getElementById('progress-section'),
      progressText=document.getElementById('progress-text'),progressSub=document.getElementById('progress-sub'),
      resultsSec=document.getElementById('results-section');
let selectedFile=null;

dropZone.addEventListener('click',()=>fileInput.click());
dropZone.addEventListener('dragover',e=>{e.preventDefault();dropZone.classList.add('drag-over')});
dropZone.addEventListener('dragleave',()=>dropZone.classList.remove('drag-over'));
dropZone.addEventListener('drop',e=>{e.preventDefault();dropZone.classList.remove('drag-over');if(e.dataTransfer.files.length)pickFile(e.dataTransfer.files[0])});
fileInput.addEventListener('change',()=>{if(fileInput.files.length)pickFile(fileInput.files[0])});
function pickFile(f){selectedFile=f;fileNameEl.textContent=`📁 ${f.name}  (${(f.size/1024/1024).toFixed(1)} MB)`;analyzeBtn.disabled=false}

analyzeBtn.addEventListener('click',async()=>{
  if(!selectedFile)return;analyzeBtn.disabled=true;uploadSec.classList.add('hidden');
  progressSec.classList.remove('hidden');resultsSec.classList.add('hidden');resultsSec.innerHTML='';
  progressText.textContent='Uploading video…';
  const fd=new FormData();fd.append('video',selectedFile);
  try{const res=await fetch('/upload',{method:'POST',body:fd});const d=await res.json();if(d.error){showErr(d.error);return}poll(d.job_id)}catch(e){showErr(e.message)}
});

function poll(id){const iv=setInterval(async()=>{
  try{const r=await fetch(`/status/${id}`);const d=await r.json();progressText.textContent=d.progress||'Processing…';
  if(d.status==='done'){clearInterval(iv);const rr=await fetch(`/results/${id}`);render(await rr.json())}
  else if(d.status==='error'){clearInterval(iv);showErr(d.progress)}}catch(e){clearInterval(iv);showErr(e.message)}},1400)}

function showErr(m){progressSec.classList.add('hidden');uploadSec.classList.remove('hidden');analyzeBtn.disabled=false;alert('❌ '+m)}

/* ═══════════════════════ RENDER ═══════════════════════ */
function render(R){
  progressSec.classList.add('hidden');resultsSec.classList.remove('hidden');resultsSec.innerHTML='';
  const C=R.counselling||{};const pred=R.final_predictions||{};

  /* 1 ─── Counsellor Banner ─── */
  resultsSec.insertAdjacentHTML('beforeend',`
  <div class="counsellor-banner slide-up">
    <h2>🧠 Your AI Counsellor's Assessment</h2>
    <div class="subtitle">Powered by Gemini AI — personalised just for you</div>
    <div class="summary">${C.overall_summary||'Analysis complete. See your detailed results below.'}</div>
    ${C.personality_snapshot?`<div class="personality">${C.personality_snapshot}</div>`:''}
  </div>`);

  /* 2 ─── Strengths & Weaknesses ─── */
  const strengths=C.strengths||[];const weaknesses=C.weaknesses||[];
  let swHTML='<div class="card slide-up"><h2>💡 Your Strengths & Weaknesses</h2>';
  // Strengths
  if(strengths.length){
    swHTML+='<h3 style="color:var(--green)">✅ Strengths</h3><div class="sw-grid">';
    strengths.forEach(s=>swHTML+=`<div class="sw-item sw-strength"><div class="sw-title">💪 ${esc(s.title)}</div><div class="sw-detail">${esc(s.detail)}</div></div>`);
    swHTML+='</div>';
  }
  // Weaknesses
  if(weaknesses.length){
    swHTML+='<h3 style="color:var(--red);margin-top:24px">⚠️ Areas of Weakness</h3><div class="sw-grid">';
    weaknesses.forEach(w=>swHTML+=`<div class="sw-item sw-weakness"><div class="sw-title">🔍 ${esc(w.title)}</div><div class="sw-detail">${esc(w.detail)}</div></div>`);
    swHTML+='</div>';
  }
  swHTML+='</div>';
  resultsSec.insertAdjacentHTML('beforeend',swHTML);

  /* 3 ─── Scenario Predictions with AI Advice ─── */
  const scenarios=[
    {key:'job_interview',emoji:'💼',label:'Cracking a Job'},
    {key:'business_deal',emoji:'🤝',label:'Getting a Business Deal'},
    {key:'date',emoji:'❤️',label:'Going on a Date'}];
  const cs=C.scenarios||{};

  let scHTML='<div class="card slide-up"><h2>🎯 Your Success Probabilities</h2><div class="scenario-cards">';
  scenarios.forEach(s=>{
    // Prefer Gemini probability, fall back to computed
    const gemini=cs[s.key]||{};const computed=pred[s.key]||{};
    const prob=gemini.probability!=null?gemini.probability:(computed.probability||50);
    const verdict=gemini.verdict||(prob>=70?'Strong chance!':prob>=50?'Decent odds':'Needs work');
    const advice=gemini.detailed_advice||'';
    const color=prob>=70?'var(--green)':prob>=50?'var(--yellow)':'var(--red)';
    const circ=2*Math.PI*48;const off=circ-(prob/100)*circ;
    scHTML+=`
    <div class="scenario-card">
      <div class="sc-emoji">${s.emoji}</div>
      <div class="sc-label">${s.label}</div>
      <div class="ring-wrap">
        <svg width="110" height="110" viewBox="0 0 110 110">
          <circle class="ring-bg" cx="55" cy="55" r="48"/>
          <circle class="ring-fg" cx="55" cy="55" r="48" stroke="${color}" stroke-dasharray="${circ}" stroke-dashoffset="${off}"/>
        </svg>
        <div class="ring-text" style="color:${color}">${Math.round(prob)}%</div>
      </div>
      <div class="sc-verdict" style="color:${color}">${esc(verdict)}</div>
      ${advice?`<div class="sc-advice">${esc(advice)}</div>`:''}
    </div>`;
  });
  scHTML+='</div></div>';
  resultsSec.insertAdjacentHTML('beforeend',scHTML);

  /* 4 ─── Detailed Score Breakdown ─── */
  const components=[
    {key:'facial_expression',label:'😊 Facial Expression'},
    {key:'body_language',label:'🧍 Body Language'},
    {key:'voice_tone',label:'🎤 Voice Tone'},
    {key:'speech_clarity',label:'💬 Speech Clarity'},
    {key:'confidence',label:'💪 Confidence'}];
  let barHTML='<div class="card slide-up"><h2>📊 Detailed Score Breakdown</h2>';
  scenarios.forEach(s=>{
    const bd=(pred[s.key]||{}).breakdown||{};
    barHTML+=`<h3>${s.emoji} ${s.label}</h3>`;
    components.forEach(c=>{
      const v=bd[c.key]||0;const col=v>=65?'var(--green)':v>=45?'var(--yellow)':'var(--red)';
      barHTML+=`<div class="bar-group"><div class="bar-label"><span>${c.label}</span><span style="color:${col}">${v.toFixed(1)}</span></div><div class="bar-track"><div class="bar-fill" style="width:${v}%;background:${col}"></div></div></div>`;
    });
  });
  barHTML+='</div>';
  resultsSec.insertAdjacentHTML('beforeend',barHTML);

  /* 5 ─── Improvement Plan ─── */
  const plan=C.improvement_plan||[];
  if(plan.length){
    let planHTML='<div class="card slide-up"><h2>🗺️ Your Personal Improvement Plan</h2>';
    plan.forEach(p=>{
      const pc=p.priority==='high'?'priority-high':p.priority==='low'?'priority-low':'priority-medium';
      planHTML+=`<div class="plan-item">
        <div class="plan-header"><span class="plan-area">${esc(p.area)}</span><span class="plan-priority ${pc}">${p.priority} priority</span></div>
        <div class="plan-states">
          <div class="plan-state state-now"><div class="ps-label">📍 Where you are now</div>${esc(p.current_state||'')}</div>
          <div class="plan-state state-target"><div class="ps-label">🎯 Where you should be</div>${esc(p.target_state||'')}</div>
        </div>
        <ul class="plan-steps">${(p.action_steps||[]).map(a=>`<li>${esc(a)}</li>`).join('')}</ul>
      </div>`;
    });
    planHTML+='</div>';
    resultsSec.insertAdjacentHTML('beforeend',planHTML);
  }

  /* 6 ─── Closing Message ─── */
  if(C.closing_message){
    resultsSec.insertAdjacentHTML('beforeend',`<div class="closing-box slide-up">💬 ${esc(C.closing_message)}</div>`);
  }

  /* 7 ─── Analyse Another / Export ─── */
  resultsSec.insertAdjacentHTML('beforeend',`
  <div style="text-align:center;margin-top:4px;display:flex;justify-content:center;gap:15px;" class="slide-up">
    <button onclick="exportToPDF()" style="padding:13px 40px;font-size:.92rem;font-weight:600;background:var(--accent);border:none;color:white;border-radius:12px;cursor:pointer;transition:.2s">📄 Export to PDF</button>
    <button onclick="resetUI()" style="padding:13px 40px;font-size:.92rem;font-weight:600;background:var(--card);border:1px solid var(--border);color:var(--accent2);border-radius:12px;cursor:pointer;transition:.2s">🔄 Analyse Another Video</button>
  </div>`);
}

function exportToPDF() {
  const element = document.getElementById('results-section');
  const opt = {
    margin:       [0.5, 0.5, 0.5, 0.5],
    filename:     'behaviour_analysis_report.pdf',
    image:        { type: 'jpeg', quality: 0.98 },
    html2canvas:  { scale: 2, useCORS: true, backgroundColor: '#0b0d13' },
    jsPDF:        { unit: 'in', format: 'a4', orientation: 'portrait' }
  };
  html2pdf().set(opt).from(element).save();
}

function esc(s){return s?String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'):'';}
function resetUI(){selectedFile=null;fileInput.value='';fileNameEl.textContent='';analyzeBtn.disabled=true;resultsSec.classList.add('hidden');resultsSec.innerHTML='';uploadSec.classList.remove('hidden')}
</script>
</body>
</html>
